  <!-- DIAGRAMA 3: Ciclo de vida del turno -->
  <diagram id="appointment-lifecycle" name="Ciclo de Vida del Turno">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title3" value="Ciclo de Vida del Turno" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#1a2047;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- States -->
        <mxCell id="start" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#272673;strokeColor=#1a2047;" vertex="1" parent="1">
          <mxGeometry x="480" y="80" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="pending" value="⏳&lt;br/&gt;&lt;b&gt;PENDIENTE&lt;/b&gt;&lt;br/&gt;Turno creado&lt;br/&gt;15 min para activar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="160" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="active" value="✅&lt;br/&gt;&lt;b&gt;ACTIVO&lt;/b&gt;&lt;br/&gt;Cliente llegó&lt;br/&gt;a la sucursal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#059669;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="340" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="attended" value="🏆&lt;br/&gt;&lt;b&gt;ATENDIDO&lt;/b&gt;&lt;br/&gt;Servicio completado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="520" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="expired" value="⌛&lt;br/&gt;&lt;b&gt;EXPIRADO&lt;/b&gt;&lt;br/&gt;No llegó en 15 min&lt;br/&gt;(Background Service)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="160" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="cancelled" value="❌&lt;br/&gt;&lt;b&gt;CANCELADO&lt;/b&gt;&lt;br/&gt;Cliente o Admin&lt;br/&gt;canceló el turno" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f4f6;strokeColor=#6b7280;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="160" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="end" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#272673;strokeColor=#1a2047;" vertex="1" parent="1">
          <mxGeometry x="480" y="660" width="40" height="40" as="geometry" />
        </mxCell>

        <!-- Transitions -->
        <mxCell id="t1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#272673;strokeWidth=2;" edge="1" parent="1" source="start" target="pending">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="Cliente activa&lt;br/&gt;(dentro de 15 min)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#059669;strokeWidth=2;fontColor=#059669;" edge="1" parent="1" source="pending" target="active">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="Admin marca&lt;br/&gt;como atendido" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2563eb;strokeWidth=2;fontColor=#2563eb;" edge="1" parent="1" source="active" target="attended">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t4" value="Pasan 15 min&lt;br/&gt;sin activar" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#dc2626;strokeWidth=2;fontColor=#dc2626;" edge="1" parent="1" source="pending" target="expired">
